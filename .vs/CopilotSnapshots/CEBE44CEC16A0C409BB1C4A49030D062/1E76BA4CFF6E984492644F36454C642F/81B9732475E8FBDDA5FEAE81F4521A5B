        if not summary['findings']:
            tree.insert('', 'end', values=('OK', 'Chưa phát hiện lỗi lớn', '', '', 'Dữ liệu hiện tương đối sạch', '', 'Có thể tiếp tục kiểm tra trước khi khóa sổ.'))
