                     values=[f"{p[0]} - {p[1]}" for p in projects], width=36).grid(row=0, column=1)
        tk.Label(frame, text="Ngày:").grid(row=1, column=0)
        tk.Entry(frame, textvariable=self.date_var, width=38).grid(row=1, column=1)
        tk.Label(frame, text="Doanh thu:").grid(row=2, column=0)
        tk.Entry(frame, textvariable=self.amount_var, width=38).grid(row=2, column=1)
        tk.Label(frame, text="VAT:").grid(row=3, column=0)
        tk.Entry(frame, textvariable=self.vat_var, width=38).grid(row=3, column=1)
