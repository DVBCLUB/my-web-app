                 command=self._export_errors).pack(side='left', padx=4)

        tk.Button(right, text="Xóa mẫu", bg=TEXT_SECONDARY,
                 fg='white', font=('Segoe UI', 10), padx=12, pady=8,
                 command=self._clear_sample).pack(side='left', padx=4)

        tk.Button(right, text="Hủy", bg=TEXT_MUTED,
                 fg='white', font=('Segoe UI', 10), padx=12, pady=8,
                 command=self.destroy).pack(side='left', padx=4)

    def _on_cell_focus(self, row, col):
        """Track active cell"""
        self.active_cell = (row, col)

    def _validate_row(self, row_idx):
        """Validate a single row"""
        if not self.validator:
            return

        row_data = [var.get().strip() for var in self.cells[row_idx]]
        result = self.validator.validate_row(row_data, row_idx)
        self.validation_results[row_idx] = result

        # Update visual indicator
        indicator = self.row_indicators[row_idx]
        if result.is_empty:
            indicator.configure(bg='white', fg=TEXT_MUTED)
            indicator.config(text="")
        elif result.status.value == 'valid':
            indicator.configure(bg=ACCENT_GREEN, fg='white')
            indicator.config(text="✓")
        elif result.status.value == 'warning':
            indicator.configure(bg=ACCENT_AMBER, fg='white')
            indicator.config(text="⚠")
        else:  # error
            indicator.configure(bg=ACCENT_RED, fg='white')
            indicator.config(text="✗")

        self._update_summary()

    def _debounce_validate_row(self, row_idx):
        """Debounced row validation on keystroke"""
        self.after(500, lambda: self._validate_row(row_idx))

    def _paste_from_clipboard(self, _event=None):
        """Handle Ctrl+V paste"""
        try:
            text = self.clipboard_get()
        except Exception:
            return 'break'

        start_row, start_col = self.active_cell
        for r_offset, line in enumerate(text.splitlines()):
            values = line.split('\t')
            for c_offset, value in enumerate(values):
                row = start_row + r_offset
                col = start_col + c_offset
                if row < len(self.cells) and col < len(self.HEADERS):
                    self.cells[row][col].set(value.strip())
                    self._validate_row(row)
        return 'break'

    def _update_summary(self):
        """Update summary cards"""
        for widget in self.summary_frame.winfo_children():
            widget.destroy()

        if not self.validator:
            return

        # Count rows
        total_rows = len(self.cells)
        non_empty = sum(1 for r in self.cells if any(v.get().strip() for v in r))

        # Validate all
        all_results = []
        for row_idx in range(total_rows):
            if row_idx not in self.validation_results:
                row_data = [v.get().strip() for v in self.cells[row_idx]]
                result = self.validator.validate_row(row_data, row_idx)
                self.validation_results[row_idx] = result
            all_results.append(self.validation_results[row_idx])

        summary = self.validator.get_summary(all_results)

        # Summary cards
        cards = [
            ('Tổng', str(total_rows), TEXT_SECONDARY),
            ('Hợp lệ', str(summary['valid']), ACCENT_GREEN),
            ('Cảnh báo', str(summary['warning']), ACCENT_AMBER),
            ('Lỗi', str(summary['error']), ACCENT_RED),
        ]

        for label, value, color in cards:
            card = tk.Frame(self.summary_frame, bg=PANEL_BG,
                           highlightbackground=PANEL_BORDER,
                           highlightthickness=1)
            card.pack(fill='x', pady=4)

            tk.Label(card, text=label, bg=PANEL_BG,
                    fg=TEXT_MUTED, font=('Segoe UI', 8)).pack(anchor='w', padx=8, pady=(6, 2))

            tk.Label(card, text=value, bg=PANEL_BG,
                    fg=color, font=('Segoe UI', 16, 'bold')).pack(anchor='w', padx=8, pady=(0, 6))

    def _export_errors(self):
        """Export validation errors"""
        if not self.validation_results:
            messagebox.showinfo("Thông báo", "Không có lỗi để xuất.")
            return

        errors_text = self.validator.export_errors(list(self.validation_results.values()))

        # Show in message box or copy to clipboard
        messagebox.showinfo("Lỗi Validation", errors_text[:500] + ("..." if len(errors_text) > 500 else ""))

    def _clear_sample(self):
        """Clear the sample data"""
        for row_cells in self.cells:
            for var in row_cells:
                var.set('')

    def _save(self):
        """Save valid rows"""
        rows = []
        errors = []

        if not self.validator:
            messagebox.showerror("Lỗi", "Validator không khả dụng")
            return

        # Validate all rows
        for index, vars_row in enumerate(self.cells, 1):
            row_data = [var.get().strip() for var in vars_row]
            result = self.validator.validate_row(row_data, index - 1)

            if result.is_empty:
                continue

            if not result.is_valid:
                errors.append(f"Dòng {index}: {'; '.join(result.error_messages)}")
                continue

            if result.parsed_data:
                rows.append({
                    'date': result.parsed_data.get('date', ''),
                    'project_id': int(result.parsed_data.get('project_id', 0)) if result.parsed_data.get('project_id') else None,
                    'category_id': int(result.parsed_data.get('category_id', 0)) if result.parsed_data.get('category_id') else None,
                    'description': result.parsed_data.get('description', ''),
                    'amount': float(result.parsed_data.get('amount', 0)),
                    'paid_by': result.parsed_data.get('paid_by', ''),
                    'method': result.parsed_data.get('method', 'Tiền mặt'),
                    'notes': result.parsed_data.get('notes', ''),
                    'extra_fields': {
                        'department': result.parsed_data.get('department', ''),
                        'purpose': result.parsed_data.get('purpose', ''),
                        'item_list': result.parsed_data.get('item_list', ''),
                        'accounting_staff': result.parsed_data.get('accounting_staff', ''),
                        'department_head': result.parsed_data.get('department_head', ''),
                        'prepared_by': result.parsed_data.get('prepared_by', ''),
                        'attachments': result.parsed_data.get('attachments', ''),
                    },
                })

        if not rows:
            messagebox.showwarning("Chưa có dữ liệu hợp lệ",
                                 "\n".join(errors[:8]) or "Không có dòng hợp lệ.")
            return

        if errors and not messagebox.askyesno("Có dòng lỗi",
            f"Có {len(errors)} dòng lỗi, vẫn lưu {len(rows)} dòng hợp lệ?\n\n" + "\n".join(errors[:5])):
            return

        self.result = {'rows': rows, 'errors': errors}
        self.destroy()
        self.destroy()


