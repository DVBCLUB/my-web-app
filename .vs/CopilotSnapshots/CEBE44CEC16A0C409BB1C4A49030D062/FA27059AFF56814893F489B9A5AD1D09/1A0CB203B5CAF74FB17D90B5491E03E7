    def _load_expense(self, expense_id):
        try:
            from modules.accounting import ExpenseManager
            row = ExpenseManager().get_expense_by_id(expense_id)
            if row:
                self._fill_expense(row)
        except Exception as exc:
            messagebox.showerror("Lỗi", f"Không tải được chi phí: {exc}")

    def _fill_expense(self, row):
        from utils import format_date
        if row.get('expense_date'):
            try:
                self.date_var.set(format_date(row['expense_date'], '%d/%m/%Y'))
            except Exception:
                self.date_var.set(str(row['expense_date']))
        if row.get('project_id'):
            for val in self.project_combo['values']:
                if val.startswith(f"{row['project_id']} -"):
                    self.project_var.set(val)
                    break
        self._reload_project_links()
        if row.get('category_id'):
            conn = get_connection()
            cur = conn.cursor()
            cur.execute('SELECT id, name FROM expense_categories WHERE id = ?', (row['category_id'],))
            cat = cur.fetchone()
            conn.close()
            if cat:
                self.category_var.set(f"{cat[0]} - {cat[1]}")
        if row.get('contract_id'):
            for val in self.contract_combo['values']:
                if val.startswith(f"{row['contract_id']} -"):
                    self.contract_var.set(val)
                    break
        if row.get('work_item_id'):
            for val in self.work_item_combo['values']:
                if val.startswith(f"{row['work_item_id']} -"):
                    self.work_item_var.set(val)
                    break
        self.description_text.delete('1.0', 'end')
        self.description_text.insert('1.0', row.get('description') or '')
        self.amount_var.set(str(row.get('amount') or 0))
        self.paid_by_var.set(row.get('paid_by') or '')
        if row.get('payment_method'):
            self.method_var.set(row['payment_method'])
        self.notes_text.delete('1.0', 'end')
        self.notes_text.insert('1.0', row.get('notes') or '')
        for key, var in self.extra_vars.items():
            if row.get(key):
                var.set(row[key])

    def _get_projects(self):
        """Lấy danh sách dự án."""
        try:
            conn = get_connection()
            cursor = conn.cursor()
            cursor.execute('SELECT id, name FROM projects WHERE status = "active"')
            projects = cursor.fetchall()
            conn.close()
            return [f"{p[0]} - {p[1]}" for p in projects]
        except:
            return []

    def _get_categories(self):
        """Lấy danh sách loại chi phí."""
        try:
            conn = get_connection()
            cursor = conn.cursor()
            cursor.execute('SELECT id, name FROM expense_categories ORDER BY name')
            categories = cursor.fetchall()
            conn.close()
            return [f"{c[0]} - {c[1]}" for c in categories]
        except:
            return []

    def _reload_project_links(self):
        project_id = _parse_combo_id(self.project_var.get())
        contracts = ['']
        work_items = ['']
        if project_id:
            try:
                conn = get_connection()
                cursor = conn.cursor()
                cursor.execute('''
                    SELECT id, contract_no, partner_name FROM project_contracts
                    WHERE project_id = ? ORDER BY contract_no
                ''', (project_id,))
                contracts.extend([f"{r[0]} - {r[1]} ({r[2]})" for r in cursor.fetchall()])
                cursor.execute('''
                    SELECT id, item_code, item_name FROM construction_work_items
                    WHERE project_id = ? ORDER BY item_code
                ''', (project_id,))
                work_items.extend([f"{r[0]} - {r[1]} {r[2]}" for r in cursor.fetchall()])
                conn.close()
            except Exception:
                pass
        self.contract_combo['values'] = contracts
        self.work_item_combo['values'] = work_items
        if contracts:
            self.contract_combo.current(0)
        if work_items:
            self.work_item_combo.current(0)

    def _save(self):
        """Lưu dữ liệu."""
        # Kiểm tra dữ liệu
        if not self.amount_var.get().strip():
            messagebox.showwarning("Lỗi", "Vui lòng nhập số tiền!")
            return

        if not self.category_var.get():
            messagebox.showwarning("Lỗi", "Vui lòng chọn loại chi phí!")
            return

        try:
            self.result = {
                'expense_id': self.expense_id,
                'date': self.date_var.get(),
                'project_id': _parse_combo_id(self.project_var.get()),
                'category_id': _parse_combo_id(self.category_var.get()),
                'contract_id': _parse_combo_id(self.contract_var.get()),
                'work_item_id': _parse_combo_id(self.work_item_var.get()),
                'description': self.description_text.get('1.0', 'end-1c'),
                'amount': parse_number(self.amount_var.get()),
                'paid_by': self.paid_by_var.get(),
                'method': self.method_var.get(),
                'notes': self.notes_text.get('1.0', 'end-1c'),
                'extra_fields': {key: var.get().strip() for key, var in self.extra_vars.items()},
            }
            self.destroy()
        except ValueError:
            messagebox.showerror("Lỗi", "Số tiền không hợp lệ!")


class BulkExpenseDialog(tk.Toplevel):
    """Nhập nhiều chi phí bằng cách dán bảng từ Excel."""

    HEADERS = [
        'Ngày', 'Dự án ID', 'Loại chi phí ID', 'Mô tả', 'Số tiền',
        'Người chi', 'Hình thức', 'Ghi chú', 'Phòng ban',
        'Mục đích sử dụng', 'Nội dung lên mẫu', 'Kế toán ký',
        'Trưởng phòng ký', 'Người lập', 'Hồ sơ đính kèm'
    ]

    def __init__(self, parent):
        super().__init__(parent)
        self.title("Nhập chi phí hàng loạt")
        self.geometry("1080x640")
        self.minsize(920, 540)
        self.result = None
        self._build()
        self.transient(parent)
        self.grab_set()

    def _build(self):
        frame = tk.Frame(self, bg='#f0f4f8')
        frame.pack(fill='both', expand=True, padx=14, pady=14)

        tk.Label(
            frame,
            text="Dán dữ liệu từ Excel theo đúng thứ tự cột bên dưới. Có thể dán cả dòng tiêu đề.",
            bg='#f0f4f8', fg='#17324D', font=('Arial', 10, 'bold')
        ).pack(anchor='w')

        header_text = '\t'.join(self.HEADERS)
        tk.Label(frame, text=header_text, bg='#f0f4f8', fg='#6B7280',
                 font=('Consolas', 9), wraplength=1020, justify='left').pack(anchor='w', pady=(6, 8))

        text_wrap = tk.Frame(frame)
        text_wrap.pack(fill='both', expand=True)
        self.text = tk.Text(text_wrap, font=('Consolas', 10), wrap='none', undo=True)
        y_scroll = ttk.Scrollbar(text_wrap, orient='vertical', command=self.text.yview)
        x_scroll = ttk.Scrollbar(text_wrap, orient='horizontal', command=self.text.xview)
        self.text.configure(yscrollcommand=y_scroll.set, xscrollcommand=x_scroll.set)
        self.text.grid(row=0, column=0, sticky='nsew')
        y_scroll.grid(row=0, column=1, sticky='ns')
        x_scroll.grid(row=1, column=0, sticky='ew')
        text_wrap.rowconfigure(0, weight=1)
        text_wrap.columnconfigure(0, weight=1)

        sample = [
            '18/05/2026', '', '', 'Thuê xe cẩu chở vật tư về dự án',
            '5,940,000.000', 'Nguyễn Văn A', 'Tiền mặt', '',
            'Phòng VT-TB', 'Phục vụ dự án', 'Thuê xe cẩu chở vật tư',
            'Kế toán', 'Trưởng phòng', 'Người lập', 'Hóa đơn; Biên bản giao hàng'
        ]
        self.text.insert('1.0', '\t'.join(sample))

        buttons = tk.Frame(frame, bg='#f0f4f8')
        buttons.pack(fill='x', pady=(10, 0))
        tk.Button(buttons, text="Lưu tất cả dòng hợp lệ", bg='#27ae60', fg='white',
                  font=('Arial', 10, 'bold'), padx=18, pady=8, command=self._save).pack(side='left', padx=4)
        tk.Button(buttons, text="Xóa dữ liệu mẫu", bg='#34495e', fg='white',
                  font=('Arial', 10), padx=18, pady=8,
                  command=lambda: self.text.delete('1.0', 'end')).pack(side='left', padx=4)
        tk.Button(buttons, text="Hủy", bg='#95a5a6', fg='white',
                  font=('Arial', 10), padx=18, pady=8, command=self.destroy).pack(side='left', padx=4)

    def _save(self):
        rows = []
        errors = []
        raw_lines = [line for line in self.text.get('1.0', 'end-1c').splitlines() if line.strip()]
        for index, line in enumerate(raw_lines, 1):
            parts = line.split('\t')
            if len(parts) == 1:
                parts = [p.strip() for p in line.split('|')]
            parts = [p.strip() for p in parts]
            if index == 1 and parts and parts[0].lower() in ('ngày', 'ngay'):
                continue
            if len(parts) < 5:
                errors.append(f"Dòng {index}: thiếu cột bắt buộc.")
                continue
            parts.extend([''] * (len(self.HEADERS) - len(parts)))
            try:
                amount = parse_number(parts[4])
                if not parts[3] or amount <= 0:
                    raise ValueError("thiếu mô tả hoặc số tiền <= 0")
                rows.append({
                    'date': format_date(parts[0] or datetime.now(), '%Y-%m-%d'),
                    'project_id': int(parts[1]) if parts[1] else None,
                    'category_id': int(parts[2]) if parts[2] else None,
                    'description': parts[3],
                    'amount': amount,
                    'paid_by': parts[5],
                    'method': parts[6] or 'Tiền mặt',
                    'notes': parts[7],
                    'extra_fields': {
                        'department': parts[8],
                        'purpose': parts[9],
                        'item_list': parts[10],
                        'accounting_staff': parts[11],
                        'department_head': parts[12],
                        'prepared_by': parts[13],
                        'attachments': parts[14],
                    },
                })
            except Exception as exc:
                errors.append(f"Dòng {index}: {exc}")

        if not rows:
            messagebox.showwarning("Chưa có dữ liệu hợp lệ", "\n".join(errors[:8]) or "Không có dòng hợp lệ.")
            return
        if errors and not messagebox.askyesno(
            "Có dòng lỗi",
            f"Có {len(errors)} dòng lỗi, vẫn lưu {len(rows)} dòng hợp lệ?\n\n" + "\n".join(errors[:6])
        ):
            return
        self.result = {'rows': rows, 'errors': errors}
        self.destroy()


