def _style_dialog_tree(root):
    """Apply the softer form treatment from the design system to legacy dialogs."""
    for widget in root.winfo_children():
        if isinstance(widget, tk.Label):
            try:
                widget.configure(bg=widget.master.cget('bg'), fg=TEXT_SECONDARY, font=('Segoe UI', 9, 'bold'))
            except tk.TclError:
                pass
        elif isinstance(widget, tk.Entry):
            _style_plain_input(widget)
        elif isinstance(widget, tk.Text):
            _style_plain_input(widget)
        elif isinstance(widget, tk.Button):
            try:
                widget.configure(font=('Segoe UI', 10, 'bold'), padx=16, pady=8, bd=0, relief='flat')
            except tk.TclError:
                pass
        _style_dialog_tree(widget)


def _style_plain_input(widget):
    try:
        widget.configure(
            font=('Segoe UI', 10),
            bg='#F8FAFC',
            fg=TEXT_PRIMARY,
            relief='flat',
            bd=0,
            insertbackground=ACCENT_BLUE,
            highlightthickness=1,
            highlightbackground=PANEL_BORDER,
            highlightcolor=ACCENT_BLUE,
        )
    except tk.TclError:
        pass


class OCRProgressDialog(tk.Toplevel):
    """
    Progress dialog cho OCR async processing.
    Hiển thị trạng thái, có nút Cancel để dừng OCR.
    """

    def __init__(self, parent, title="Đang xử lý OCR"):
        super().__init__(parent)
        self.title(title)
        self.geometry("400x150")
        self.resizable(False, False)
        self.transient(parent)
        self.grab_set()

        self._cancelled = False
        self._ocr_instance = None

        self._build()

    def _build(self):
        """Build dialog UI"""
        frame = tk.Frame(self, bg='#f0f4f8')
        frame.pack(fill='both', expand=True, padx=16, pady=16)

        # Status label
        self.status_var = tk.StringVar(value="Đang trích xuất text từ PDF/ảnh...")
        tk.Label(
            frame,
            textvariable=self.status_var,
            bg='#f0f4f8',
            fg='#17324D',
            font=('Arial', 10),
            justify='center'
        ).pack(fill='x', pady=(0, 12))

        # Progress bar (indeterminate)
        self.progress = ttk.Progressbar(
            frame,
            mode='indeterminate',
            length=300
        )
        self.progress.pack(fill='x', pady=(0, 16))
        self.progress.start()

        # Cancel button
        btn_frame = tk.Frame(frame, bg='#f0f4f8')
        btn_frame.pack(fill='x')
        tk.Button(
            btn_frame,
            text="Hủy",
            bg='#e74c3c',
            fg='white',
            font=('Arial', 10),
            padx=20,
            pady=6,
            command=self._cancel
        ).pack()

    def _cancel(self):
        """Cancel OCR processing"""
        self._cancelled = True
        self.status_var.set("Đang dừng...")
        if self._ocr_instance:
            try:
                self._ocr_instance.stop()
            except Exception as e:
                logger.error(f"Error stopping OCR: {e}")

    def set_status(self, text):
        """Update status text"""
        self.status_var.set(text)
        self.update_idletasks()

    def set_ocr_instance(self, ocr_instance):
        """Set OCR instance for cancellation"""
        self._ocr_instance = ocr_instance

    def is_cancelled(self):
        """Check if user cancelled"""
        return self._cancelled



def _parse_combo_id(value):
    """Lấy ID từ chuỗi combobox dạng '12 - Tên'."""
    if not value:
        return None
    return int(str(value).split(' - ', 1)[0])


def _parse_combo_prefix(value):
    """Lấy phần đầu chuỗi combobox dạng '111 - Tên'."""
    if not value:
        return None
    return str(value).split(' - ', 1)[0]


def _get_simple_catalog_values(catalog_type):
    try:
        conn = get_connection()
        cursor = conn.cursor()
        cursor.execute('''
            SELECT name FROM simple_catalogs
            WHERE catalog_type = ? AND active = 1
            ORDER BY name
        ''', (catalog_type,))
        rows = cursor.fetchall()
        conn.close()
        return [r[0] for r in rows]
    except Exception:
        return []


