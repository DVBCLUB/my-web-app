        self.project_var = tk.StringVar(value=f"{projects[0][0]} - {projects[0][1]}" if projects else '')
        self.date_var = tk.StringVar(value=datetime.now().strftime('%Y-%m-%d'))
        self.amount_var = tk.StringVar(value='0')
        self.vat_var = tk.StringVar(value='0')
        self.desc_var = tk.StringVar()
        tk.Label(frame, text="Dự án:").grid(row=0, column=0)
