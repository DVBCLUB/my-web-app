    def _load_document(self, document_id):
        try:
            from modules.invoices import DocumentManager
            doc = DocumentManager().get_document_by_id(document_id)
            if not doc:
                return
            self.document_id = document_id
            self.doc_type_var.set(doc.get('doc_type') or 'Hóa đơn')
            self.doc_number_var.set(doc.get('doc_number') or '')
            from utils import format_date
            if doc.get('doc_date'):
                try:
                    self.doc_date_var.set(format_date(doc['doc_date'], '%d/%m/%Y'))
                except Exception:
                    self.doc_date_var.set(str(doc['doc_date']))
            self.supplier_var.set(doc.get('supplier_name') or '')
            self.description_text.delete('1.0', 'end')
            self.description_text.insert('1.0', doc.get('description') or '')
            self.amount_var.set(str(doc.get('amount') or 0))
            self.vat_rate_var.set(str(doc.get('vat_rate') or 10))
            self.status_var.set(doc.get('status') or 'draft')
            if doc.get('expense_id'):
                for val in self.expense_combo['values']:
                    if val.startswith(f"{doc['expense_id']} -"):
                        self.expense_var.set(val)
                        break
        except Exception as exc:
            messagebox.showerror("Lỗi", f"Không tải chứng từ: {exc}")

    def _get_expenses(self):
        """Lấy danh sách nghiệp vụ chi phí để liên kết chứng từ."""
        try:
            conn = get_connection()
            cursor = conn.cursor()
            cursor.execute('''
                SELECT e.id, e.expense_date, COALESCE(p.name, 'Không có dự án'),
                       COALESCE(ec.name, 'Chưa phân loại'), e.amount
                FROM expenses e
                LEFT JOIN projects p ON e.project_id = p.id
                LEFT JOIN expense_categories ec ON e.category_id = ec.id
                ORDER BY e.expense_date DESC, e.id DESC
            ''')
            expenses = cursor.fetchall()
            conn.close()
            return [
                f"{e[0]} - {e[1]} - {e[2]} - {e[3]} - {e[4]:,.0f}"
                for e in expenses
            ]
        except Exception:
            return []

    def _save(self):
        """Lưu dữ liệu."""
        if not self.doc_type_var.get():
            messagebox.showwarning("Lỗi", "Vui lòng chọn loại chứng từ!")
            return

        if not self.amount_var.get().strip():
            messagebox.showwarning("Lỗi", "Vui lòng nhập số tiền!")
            return

        if not self.expense_var.get():
            messagebox.showwarning("Lỗi", "Vui lòng chọn nghiệp vụ chi phí để liên kết chứng từ!")
            return

        try:
            self.result = {
                'document_id': self.document_id,
                'doc_type': self.doc_type_var.get(),
                'doc_number': self.doc_number_var.get(),
                'doc_date': self.doc_date_var.get(),
                'supplier': self.supplier_var.get(),
                'description': self.description_text.get('1.0', 'end-1c'),
                'amount': parse_number(self.amount_var.get()),
                'vat_rate': parse_number(self.vat_rate_var.get() or '10'),
                'expense_id': _parse_combo_id(self.expense_var.get()),
                'status': self.status_var.get(),
            }
            self.destroy()
        except ValueError:
            messagebox.showerror("Lỗi", "Dữ liệu không hợp lệ!")


