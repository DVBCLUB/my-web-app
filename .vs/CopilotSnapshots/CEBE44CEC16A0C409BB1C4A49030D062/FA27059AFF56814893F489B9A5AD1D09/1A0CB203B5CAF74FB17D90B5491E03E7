    def _text(self, key):
        widget = self.text_widgets.get(key)
        return widget.get('1.0', 'end-1c') if widget else ''

    def _save(self):
        project_id = _parse_combo_id(self.vars['project_id'].get())
        try:
            data = {'project_id': project_id}
            if self.record_type == 'work_item':
                data.update({
                    'item_code': self.vars['item_code'].get().strip(),
                    'item_name': self.vars['item_name'].get().strip(),
                    'unit': self.vars['unit'].get().strip(),
                    'planned_quantity': self._num('planned_quantity'),
                    'completed_quantity': self._num('completed_quantity'),
                    'unit_price': self._num('unit_price'),
                    'status': self.vars['status'].get().strip(),
                    'notes': self._text('notes'),
                })
                if not data['item_name']:
                    raise ValueError('Vui lòng nhập tên hạng mục.')
            elif self.record_type == 'diary':
                data.update({key: self.vars[key].get().strip() for key in ['diary_date', 'weather', 'manpower', 'equipment', 'reporter']})
                data['work_content'] = self._text('work_content')
                data['issues'] = self._text('issues')
            elif self.record_type == 'milestone':
                data.update({key: self.vars[key].get().strip() for key in ['milestone_name', 'planned_date', 'actual_date', 'status']})
                data['notes'] = self._text('notes')
            elif self.record_type == 'equipment':
                data.update({
                    'usage_date': self.vars['usage_date'].get().strip(),
                    'equipment_name': self.vars['equipment_name'].get().strip(),
                    'operator': self.vars['operator'].get().strip(),
                    'hours': self._num('hours'),
                    'fuel_cost': self._num('fuel_cost'),
                    'notes': self._text('notes'),
                })
            else:
                data.update({key: self.vars[key].get().strip() for key in ['check_date', 'check_item', 'result', 'responsible', 'deadline', 'status']})
                data['action_required'] = self._text('action_required')
            self.result = data
            self.destroy()
        except ValueError as exc:
            messagebox.showerror("Lỗi", str(exc))


