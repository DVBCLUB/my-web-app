        source_combo.bind('<<ComboboxSelected>>', lambda _event: self._refresh_records())

        search_frame = tk.Frame(frame, bg='#f0f4f8')
        search_frame.grid(row=2, column=0, columnspan=2, sticky='ew', pady=6)
        tk.Label(search_frame, text="Tìm nghiệp vụ:", font=('Arial', 10), bg='#f0f4f8').pack(side='left')
        self.search_var = tk.StringVar()
        tk.Entry(search_frame, textvariable=self.search_var, font=('Arial', 10), width=32).pack(side='left', padx=6)
        tk.Button(search_frame, text="Tìm", bg='#2874A6', fg='white', padx=12, pady=6,
                  command=self._refresh_records).pack(side='left')

        records_frame = tk.LabelFrame(frame, text="  Nghiệp vụ liên kết  ", bg='#f0f4f8', fg='#17324D',
                                      font=('Arial', 10, 'bold'), padx=8, pady=8)
        records_frame.grid(row=3, column=0, columnspan=2, sticky='nsew', pady=6)
        self.records_tree = ttk.Treeview(records_frame, columns=('ID', 'Ngày/Mã', 'Đối tượng', 'Nội dung', 'Số tiền', 'Trạng thái'),
                                         height=7, show='tree headings')
        for col, width in zip(('ID', 'Ngày/Mã', 'Đối tượng', 'Nội dung', 'Số tiền', 'Trạng thái'), (60, 100, 170, 250, 100, 100)):
            self.records_tree.heading(col, text=col)
            self.records_tree.column(col, width=width)
        records_y = ttk.Scrollbar(records_frame, orient='vertical', command=self.records_tree.yview)
        records_x = ttk.Scrollbar(records_frame, orient='horizontal', command=self.records_tree.xview)
        self.records_tree.configure(yscrollcommand=records_y.set, xscrollcommand=records_x.set)
        self.records_tree.grid(row=0, column=0, sticky='nsew')
        records_y.grid(row=0, column=1, sticky='ns')
        records_x.grid(row=1, column=0, sticky='ew')
        records_frame.rowconfigure(0, weight=1)
        records_frame.columnconfigure(0, weight=1)

        manual_frame = tk.LabelFrame(frame, text="  Trường nhập thêm/thủ công  ", bg='#f0f4f8', fg='#17324D',
                                     font=('Arial', 10, 'bold'), padx=8, pady=8)
        manual_frame.grid(row=4, column=0, columnspan=2, sticky='nsew', pady=6)
        self.manual_canvas = tk.Canvas(manual_frame, bg='#f0f4f8', height=210, highlightthickness=0)
        self.manual_inner = tk.Frame(self.manual_canvas, bg='#f0f4f8')
        scrollbar = ttk.Scrollbar(manual_frame, orient='vertical', command=self.manual_canvas.yview)
        self.manual_canvas.configure(yscrollcommand=scrollbar.set)
        self.manual_canvas.create_window((0, 0), window=self.manual_inner, anchor='nw')
        self.manual_inner.bind('<Configure>', lambda _event: self.manual_canvas.configure(scrollregion=self.manual_canvas.bbox('all')))
        self.manual_canvas.pack(side='left', fill='both', expand=True)
        scrollbar.pack(side='right', fill='y')

        buttons = tk.Frame(frame, bg='#f0f4f8')
        buttons.grid(row=5, column=0, columnspan=2, sticky='ew', pady=12)
        tk.Button(buttons, text="Tạo biểu mẫu", bg='#2E7D32', fg='white', font=('Arial', 10, 'bold'),
                  padx=20, pady=8, command=self._save).pack(side='left', padx=5)
        tk.Button(buttons, text="Hủy", bg='#95a5a6', fg='white', font=('Arial', 10),
                  padx=20, pady=8, command=self.destroy).pack(side='left', padx=5)

        frame.columnconfigure(1, weight=1)
        frame.rowconfigure(3, weight=1)
        frame.rowconfigure(4, weight=1)
        self._refresh_records()
        self._build_manual_fields()

    def _source_type(self):
        return self.source_var.get().split(' - ', 1)[0]

    def _selected_form_id(self):
        if not self.form_var.get():
            return None
        return int(self.form_var.get().split(' - ', 1)[0])

    def _refresh_records(self):
        source_type = self._source_type()
        for item in self.records_tree.get_children():
            self.records_tree.delete(item)
        if source_type == 'manual':
            return
        self.record_rows = self.renderer.get_accounting_records(source_type, self.search_var.get().strip())
        for row in self.record_rows:
            values = list(row)
            while len(values) < 6:
                values.append('')
            if len(values) >= 7:
                display = (values[0], values[1], values[2], values[4], values[5], values[6])
            else:
                display = tuple(values[:6])
            self.records_tree.insert('', 'end', values=display)

    def _build_manual_fields(self):
        for child in self.manual_inner.winfo_children():
            child.destroy()
        self.manual_widgets = {}
        form_id = self._selected_form_id()
        if not form_id:
            return
        fields = self.renderer.get_form_fields(form_id)
        for idx, field in enumerate(fields):
            tk.Label(self.manual_inner, text=field['field_label'], bg='#f0f4f8',
                     font=('Arial', 10)).grid(row=idx, column=0, sticky='w', padx=5, pady=4)
            var = tk.StringVar(value=field[4] if len(field) > 4 else '')
            self.manual_widgets[field['field_key']] = var
            tk.Entry(self.manual_inner, textvariable=var, font=('Arial', 10), width=48).grid(
                row=idx, column=1, sticky='ew', padx=5, pady=4
            )
        self.manual_inner.columnconfigure(1, weight=1)

    def _manual_values(self):
        return {key: var.get().strip() for key, var in self.manual_widgets.items() if var.get().strip()}

    def _selected_record_id(self):
        if self._source_type() == 'manual':
            return None
        if not self.records_tree.selection():
            raise ValueError('Vui lòng chọn một nghiệp vụ để liên kết, hoặc chọn nguồn Nhập thủ công.')
        values = self.records_tree.item(self.records_tree.selection()[0], 'values')
        return int(values[0])

    def _save(self):
        try:
            form_id = self._selected_form_id()
            if not form_id:
                raise ValueError('Vui lòng chọn biểu mẫu.')
            source_type = self._source_type()
            record_id = self._selected_record_id()
            output_path = self.renderer.render_form(
                form_id, source_type, record_id, self._manual_values()
            )
            self.result = {'output_path': output_path}
            self.destroy()
        except Exception as exc:
            messagebox.showerror("Lỗi", str(exc))


