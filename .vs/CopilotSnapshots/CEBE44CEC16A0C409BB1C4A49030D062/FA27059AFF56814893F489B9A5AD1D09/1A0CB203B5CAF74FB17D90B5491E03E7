    def _choose_file(self):
        """Chọn file với async OCR processing"""
        from modules.document_intake import InvoiceIntakeService
        path = filedialog.askopenfilename(
            title="Chọn PDF hoặc hình ảnh",
            filetypes=[("PDF / Image", "*.pdf *.png *.jpg *.jpeg *.bmp *.tif *.tiff"), ("All files", "*.*")]
        )
        if not path:
            return

        # Show progress dialog
        progress_dialog = OCRProgressDialog(self, "Đang xử lý OCR...")

        try:
            service = InvoiceIntakeService()

            def on_ocr_result(ocr_result):
                """Callback khi OCR hoàn thành"""
                try:
                    # Check if cancelled
                    if progress_dialog.is_cancelled():
                        progress_dialog.destroy()
                        messagebox.showinfo("Đã hủy", "Xử lý OCR đã bị hủy.")
                        return

                    # Check OCR status
                    from modules.ocr_enhanced import OCRStatus
                    if ocr_result.status != OCRStatus.SUCCESS:
                        progress_dialog.destroy()
                        error_msg = ocr_result.error or "Không nhận diện được text"
                        messagebox.showerror("Lỗi OCR", f"{error_msg}\n\nHãy kiểm tra:\n- Chất lượng ảnh/PDF\n- Cài đặt Tesseract OCR\n- Gói ngôn ngữ tiếng Việt (vie)")
                        return

                    # Parse extraction result
                    progress_dialog.set_status("Đang phân tích dữ liệu...")
                    self.after_idle(lambda: self._process_ocr_result(
                        ocr_result.text,
                        path,
                        progress_dialog,
                        service
                    ))
                except Exception as e:
                    logger.exception(f"Error in OCR callback: {e}")
                    progress_dialog.destroy()
                    messagebox.showerror("Lỗi OCR", f"Lỗi xử lý kết quả: {str(e)}")

            # Start async OCR
            from modules.ocr_enhanced import OCRToolEnhanced
            ocr = OCRToolEnhanced()
            progress_dialog.set_ocr_instance(ocr)
            service.text_extractor.extract_text_async(path, on_ocr_result)

        except Exception as e:
            logger.exception(f"Error starting OCR: {e}")
            progress_dialog.destroy()
            messagebox.showerror("Lỗi OCR", f"Lỗi khởi động: {str(e)}")

    def _process_ocr_result(self, raw_text, file_path, progress_dialog, service):
        """Xử lý kết quả OCR khi hoàn thành"""
        try:
            progress_dialog.destroy()

            # Parse fields
            parsed = {}
            confidence = 0.0
            try:
                from modules.ocr_tools import InvoiceOCRParser
                parsed = InvoiceOCRParser().parse(raw_text)
                confidence = parsed.get('confidence', 0.0) or 0.0
            except Exception as e:
                logger.warning(f"Field parsing error: {e}")
                confidence = 0.3  # Low confidence nếu parse fail

            # Fill extraction result
            from modules.document_intake import InvoiceExtractionResult
            from datetime import date, timedelta

            self.extraction = InvoiceExtractionResult(
                source_file=str(file_path),
                raw_text=raw_text,
                tax_code=parsed.get('tax_code') or '',
                invoice_number=parsed.get('invoice_number') or '',
                invoice_date=parsed.get('invoice_date') or '',
                received_date=date.today().isoformat(),
                total_amount=parsed.get('total_amount') or 0.0,
                deadline=(date.today() + timedelta(days=15)).isoformat(),
            )

            # Update form fields
            values = {
                'tax_code': self.extraction.tax_code,
                'invoice_number': self.extraction.invoice_number,
                'invoice_date': self.extraction.invoice_date,
                'received_date': self.extraction.received_date,
                'deadline': self.extraction.deadline,
                'total_amount': f"{self.extraction.total_amount:,.3f}" if self.extraction.total_amount else '',
                'supplier_name': parsed.get('supplier_name') or '',
            }
            for key, var in self.field_vars.items():
                var.set(values.get(key, ''))

            # Update confidence với màu
            confidence_percent = int(confidence * 100)
            if confidence_percent >= 80:
                confidence_text = f"Độ tin cậy: {confidence_percent}% ✓"
                confidence_color = self._accent_green
            elif confidence_percent >= 50:
                confidence_text = f"Độ tin cậy: {confidence_percent}% ⚠"
                confidence_color = "#C27A10"  # Amber
            else:
                confidence_text = f"Độ tin cậy: {confidence_percent}% ✗"
                confidence_color = "#E53935"  # Red

            self.confidence_var.set(confidence_text)
            # Update color (tìm confidence label và cập nhật)
            for widget in self.winfo_children()[0].winfo_children()[1].winfo_children()[1].winfo_children():
                if isinstance(widget, tk.Label) and "Độ tin cậy" in str(widget.cget('textvariable')):
                    widget.configure(fg=confidence_color)
                    break

            # Display raw text
            self.text.delete('1.0', 'end')
            self.text.insert('1.0', raw_text)

            # Show confidence alert
            if confidence_percent < 70:
                from ui.component_library import Alert
                alert_frame = tk.Frame(self)
                alert_frame.pack(fill='x', before=self.text, padx=14, pady=(0, 8))
                Alert(alert_frame, 
                      severity="warning" if confidence_percent >= 50 else "error",
                      title="Độ tin cậy thấp",
                      message="Hãy kiểm tra kỹ và chỉnh sửa các trường để đảm bảo dữ liệu chính xác").pack(fill='x')

        except Exception as e:
            logger.exception(f"Error processing OCR result: {e}")
            messagebox.showerror("Lỗi xử lý", f"Lỗi: {str(e)}")

    def _save_document(self):
        if not self.extraction:
            messagebox.showwarning("Chưa có dữ liệu", "Vui lòng chọn file PDF/ảnh trước.")
            return
        try:
            from modules.document_intake import InvoiceIntakeService
            document_id = InvoiceIntakeService().save_to_database(self.extraction)
            messagebox.showinfo("Thành công", f"Đã lưu chứng từ ID {document_id} và deadline {self.extraction.deadline}.")
        except Exception as e:
            messagebox.showerror("Lỗi lưu chứng từ", str(e))


