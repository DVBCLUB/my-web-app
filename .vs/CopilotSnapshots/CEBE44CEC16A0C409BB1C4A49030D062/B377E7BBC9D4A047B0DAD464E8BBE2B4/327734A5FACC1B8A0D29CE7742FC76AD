def apply_ttk_styles(root):
    style = ttk.Style(root)
    try:
        style.theme_use("clam")
    except tk.TclError:
        pass

    style.configure(".", background=PAGE_BG, foreground=TEXT_PRIMARY, font=FONT_BODY)
    style.configure("TFrame", background=PAGE_BG)
    style.configure("TLabel", background=PAGE_BG, foreground=TEXT_PRIMARY, font=FONT_BODY)
    style.configure("TNotebook", background=PAGE_BG, borderwidth=0)
    style.configure(
        "TNotebook.Tab",
        padding=(14, 8),
        font=FONT_SMALL,
        background=PANEL_BORDER,
        foreground=TEXT_SECONDARY,
    )
    style.map(
        "TNotebook.Tab",
        background=[("selected", PANEL_BG), ("active", "#EBF3FF")],
        foreground=[("selected", ACCENT_BLUE), ("active", ACCENT_BLUE)],
    )

    for name in ("Treeview", "Custom.Treeview"):
        style.configure(
            name,
            background=PANEL_BG,
            fieldbackground=PANEL_BG,
            foreground=TEXT_SECONDARY,
            rowheight=28,
            font=FONT_BODY,
            bordercolor=PANEL_BORDER,
            lightcolor=PANEL_BORDER,
            darkcolor=PANEL_BORDER,
        )
        style.map(
            name,
            background=[("selected", "#EBF3FF")],
            foreground=[("selected", ACCENT_BLUE)],
        )

    for name in ("Treeview.Heading", "Custom.Treeview.Heading"):
        style.configure(
            name,
            background=PAGE_BG,
            foreground=TEXT_MUTED,
            font=FONT_SMALL,
            relief="flat",
            padding=(8, 7),
        )

    style.configure("Vertical.TScrollbar", troughcolor=PAGE_BG, background=PANEL_BORDER)
    style.configure("Horizontal.TScrollbar", troughcolor=PAGE_BG, background=PANEL_BORDER)


def create_panel(parent, **kwargs):
    return tk.Frame(
        parent,
        bg=PANEL_BG,
        bd=0,
        relief="flat",
        highlightbackground=PANEL_BORDER,
        highlightthickness=1,
        **kwargs,
    )


def create_pill(parent, text, status="pending", **kwargs):
    bg, fg = STATUS_COLORS.get(status, (PILL_PROC_BG, PILL_PROC_FG))
    return tk.Label(parent, text=text, bg=bg, fg=fg, font=FONT_SMALL,
                    padx=8, pady=2, bd=0, **kwargs)


def create_modern_button(parent, text, command, variant="primary", **kwargs):
    colors = {
        "primary": (ACCENT_BLUE, "white", "#155EA8"),
        "success": (ACCENT_GREEN, "white", "#087A46"),
        "danger": (ACCENT_RED, "white", "#C62828"),
        "warning": ("#FFC107", TEXT_PRIMARY, "#E0A800"),
        "info": (ACCENT_BLUE, "white", "#155EA8"),
        "accent": (ACCENT_BLUE, "white", "#155EA8"),
        "muted": ("#6C757D", "white", "#5A6268"),
        "secondary": (PANEL_BG, TEXT_SECONDARY, "#F8FAFC"),
        "ghost": (PANEL_BG, TEXT_SECONDARY, "#F8FAFC"),
        "outline": (PANEL_BG, TEXT_SECONDARY, "#F8FAFC"),
    }
    bg, fg, active = colors.get(variant, colors["primary"])
    font = kwargs.pop("font", ("Segoe UI", 9, "bold"))
    padx = kwargs.pop("padx", 14)
    pady = kwargs.pop("pady", 6)
    btn = tk.Button(
        parent,
        text=text,
        command=command,
        bg=bg,
        fg=fg,
        activebackground=active,
        activeforeground=fg if variant in {"secondary", "ghost", "outline"} else "white",
        font=font,
        padx=padx,
        pady=pady,
        bd=0,
        cursor="hand2",
        relief="flat",
        highlightthickness=0,
        **kwargs,
    )
    if variant in {"secondary", "ghost", "outline"}:
        btn.configure(highlightthickness=1, highlightbackground=PANEL_BORDER)
    return btn


def create_link_button(parent, text, command, **kwargs):
    btn = tk.Label(
        parent,
        text=text,
        fg=ACCENT_BLUE,
        bg=kwargs.pop("bg", PANEL_BG),
        font=kwargs.pop("font", ("Segoe UI", 9, "underline")),
        cursor="hand2",
    )
    btn.bind("<Button-1>", lambda _e: command())
    btn.bind("<Enter>", lambda _e: btn.configure(fg="#155EA8"))
    btn.bind("<Leave>", lambda _e: btn.configure(fg=ACCENT_BLUE))
    return btn


def format_status(status):
    return STATUS_LABELS.get(status, status or "")


def draw_header_accent(canvas, width, height):
    canvas.create_rectangle(0, 0, width, height, fill=TOPBAR_BG, outline="")
    canvas.create_rectangle(0, height - 1, width, height, fill=TOPBAR_BORDER, outline="")
